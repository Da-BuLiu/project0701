{
  "$schemaVersion": "0.1",
  "lineId": "137-housing-inspection",
  "description": "137 壳体自动检测线虚拟下位机节拍与资源初版。仅首件约 125 秒、稳定投料间隔约 65 秒来自现有节拍分析；单工序时长为仿真临时分配，待现场动作时序和设备接口确认后替换。",
  "timing": {
    "firstPieceTargetSeconds": 125,
    "steadyStateReleaseIntervalSeconds": 65,
    "cycleTimeAcceptanceLimitSeconds": 180,
    "acceptanceBoundary": "待确认：技术协议与需求材料对 CT 是否包含上下料的口径存在差异。"
  },
  "resources": [
    { "id": "Robot", "displayName": "上/下料机器人", "capacity": 1 },
    { "id": "TransferModule", "displayName": "搬运移栽模组", "capacity": 1 },
    { "id": "Conveyor", "displayName": "输送台与旋转伺服", "capacity": 1 },
    { "id": "EndFaceCamera", "displayName": "端面检测相机", "capacity": 1 },
    { "id": "LengthCamera", "displayName": "全长检测相机", "capacity": 1 },
    { "id": "CylinderCamera", "displayName": "柱面及端面检测相机", "capacity": 1 },
    { "id": "LineSpectrometer", "displayName": "同轴线光谱传感器", "capacity": 1 },
    { "id": "Endoscope", "displayName": "内窥镜检测模块", "capacity": 1 },
    { "id": "ThreadPlatform", "displayName": "螺纹检测平台", "capacity": 1 }
  ],
  "operations": [
    {
      "id": "OP10",
      "name": "上料机器人取料",
      "sequence": 10,
      "simulatedDurationSeconds": 12,
      "durationStatus": "temporary",
      "resources": ["Robot"],
      "timeoutSeconds": 30
    },
    {
      "id": "OP20",
      "name": "气缸二次定位",
      "sequence": 20,
      "simulatedDurationSeconds": 3,
      "durationStatus": "temporary",
      "resources": ["TransferModule"],
      "timeoutSeconds": 15
    },
    {
      "id": "OP30",
      "name": "端面检测、料号/SN 识别",
      "sequence": 30,
      "simulatedDurationSeconds": 18,
      "durationStatus": "temporary",
      "resources": ["TransferModule", "EndFaceCamera"],
      "timeoutSeconds": 45
    },
    {
      "id": "OP40",
      "name": "全长检测",
      "sequence": 40,
      "simulatedDurationSeconds": 10,
      "durationStatus": "temporary",
      "resources": ["Conveyor", "LengthCamera"],
      "timeoutSeconds": 30
    },
    {
      "id": "OP50",
      "name": "柱面及端面检测、旋转角度定位",
      "sequence": 50,
      "simulatedDurationSeconds": 20,
      "durationStatus": "temporary",
      "resources": ["Conveyor", "CylinderCamera"],
      "timeoutSeconds": 60,
      "subOperations": [
        { "id": "OP50-1", "name": "下移与第一次拍照（旋转角度采集）" },
        { "id": "OP50-2", "name": "旋转后第二次拍照" },
        { "id": "OP50-3", "name": "第三次拍照" },
        { "id": "OP50-4", "name": "抬起并转运至 OP60" }
      ]
    },
    {
      "id": "OP60",
      "name": "同轴线光谱检测",
      "sequence": 60,
      "simulatedDurationSeconds": 15,
      "durationStatus": "temporary",
      "resources": ["Conveyor", "LineSpectrometer"],
      "timeoutSeconds": 45
    },
    {
      "id": "OP70",
      "name": "内窥镜检测",
      "sequence": 70,
      "simulatedDurationSeconds": 22,
      "durationStatus": "temporary",
      "resources": ["Conveyor", "Endoscope"],
      "timeoutSeconds": 75,
      "subOperations": [
        { "id": "OP70-1", "name": "第一检测采集（120° 视野）" },
        { "id": "OP70-2", "name": "旋转 100° 后第二检测采集" },
        { "id": "OP70-3", "name": "第三检测采集" },
        { "id": "OP70-4", "name": "第四检测采集" }
      ]
    },
    {
      "id": "OP80",
      "name": "螺纹检测、OK/NG 下料",
      "sequence": 80,
      "simulatedDurationSeconds": 25,
      "durationStatus": "temporary",
      "resources": ["TransferModule", "ThreadPlatform", "Robot"],
      "timeoutSeconds": 90,
      "notes": "M8/M10 通止规检测、螺纹结果字典和最终 OK/NG 汇总规则均待确认。"
    }
  ],
  "releaseRule": {
    "type": "afterFirstPieceReachesOperation",
    "operationId": "OP80",
    "estimatedElapsedSeconds": 65,
    "status": "derived-from-existing-takt-analysis"
  }
}
